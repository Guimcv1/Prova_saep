# ============= CONFIGURAÇÃO DO BANCO DE DADOS =============
# Nome do banco de dados MySQL
DB_NAME = prova

# Host/IP do servidor MySQL
DB_HOST = 2dsmoca.tech

# Usuário do MySQL
DB_USER = root

# Senha do MySQL
DB_PASSWORD = 

# Porta do servidor MySQL (padrão: 3306)
DB_PORT = 3306

# ============= CONFIGURAÇÃO JWT E SEGURANÇA =============
# Chave secreta para assinar tokens JWT
# ⚠️ IMPORTANTE: Mude isso em produção! Use uma chave segura e aleatória
# Quanto mais longa e complexa, mais segura
SECRET_KEY = sua-chave-secreta-super-segura-mude-em-producao-change-me

# Tempo de expiração do token em minutos
# Após esse tempo, o usuário precisa fazer login novamente
ACCESS_TOKEN_EXPIRE_MINUTES = 30
